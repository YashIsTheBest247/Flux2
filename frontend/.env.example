# Optional: absolute base URL of the backend API.
# Leave empty in local dev — the Vite proxy forwards /api and /static to 127.0.0.1:8000.
# Set this when the frontend is hosted separately from the backend, e.g.
# VITE_API_BASE_URL=https://api.your-domain.com
VITE_API_BASE_URL=

# YouTube channel link shown in the header (must be VITE_-prefixed for Vite to expose it)
VITE_FLUX_CHANNEL_URL=https://youtube.com/@echoesofmyindia?si=q-RwYc6p1VVCCtD_
