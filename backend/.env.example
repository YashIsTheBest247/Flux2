# Flux Video Generator - Environment Variables Example
# Copy this file to .env and fill in your values

# ============================================
# APPLICATION SETTINGS
# ============================================

# Application environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (True/False)
DEBUG=True

# Server host and port
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated list) - include the frontend Vite dev server
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173,http://127.0.0.1:5173

# ============================================
# API KEYS (REQUIRED)
# ============================================

# Google Gemini API Key - REQUIRED for script generation (free tier) and image fallback
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model used for text generation (scripts, questions) - free tier
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Pexels API Key - PRIMARY source for scene images (free)
# Get it from: https://www.pexels.com/api/
# If a topic returns no Pexels images, the app falls back to Gemini image generation
PEXELS_API_KEY=your_pexels_api_key_here

# ============================================
# VIDEO GENERATION SETTINGS
# ============================================

# Default video duration in seconds
DEFAULT_VIDEO_DURATION=60

# Default frames per second for video output
DEFAULT_VIDEO_FPS=24

# Default chunk size for subtitle splitting
DEFAULT_CHUNK_SIZE=10

# ============================================
# IMAGE SETTINGS (Pexels primary, Gemini fallback)
# ============================================

# Gemini image model used only when Pexels has no match (e.g. gemini-2.5-flash-image)
IMAGE_GEN_MODEL=gemini-2.5-flash-image

# Image aspect ratio (1:1, 3:4, 4:3, 9:16, 16:9) - maps to Pexels orientation
IMAGE_ASPECT_RATIO=1:1

# Delay between image API calls (seconds)
IMAGE_GEN_DELAY=2.0

# ============================================
# TRENDING PIPELINE (Economic Times RSS -> short-form video)
# ============================================

# Master switch. When true, a background scheduler fetches ET feeds, ranks
# articles, and auto-generates the top N short videos on an interval.
# NOTE: enabling this consumes Gemini quota (and uploads to YouTube if
# TRENDS_AUTO_PUBLISH=true) unattended. Leave false until you're ready.
TRENDS_ENABLED=false

# Economic Times RSS feeds to monitor (comma-separated)
TRENDS_FEED_URLS=https://economictimes.indiatimes.com/rssfeedstopstories.cms,https://economictimes.indiatimes.com/markets/rssfeeds/1977021501.cms,https://economictimes.indiatimes.com/industry/rssfeeds/13352306.cms,https://economictimes.indiatimes.com/news/economy/rssfeeds/1373380680.cms,https://economictimes.indiatimes.com/tech/rssfeeds/13357270.cms

# How often to run the pipeline (hours)
TRENDS_INTERVAL_HOURS=6

# How many top-ranked articles to turn into videos each run
TRENDS_TOP_N=3

# Short-form video duration (seconds)
TRENDS_VIDEO_DURATION=60

# Ignore articles older than this many hours
TRENDS_MAX_AGE_HOURS=24

# Auto-publish trending videos to YouTube (uses YOUTUBE_PRIVACY_STATUS = private)
TRENDS_AUTO_PUBLISH=false

# Run one pipeline pass immediately on server startup (otherwise waits one interval)
TRENDS_RUN_ON_STARTUP=false

# ============================================
# YOUTUBE AUTO-PUBLISHING
# ============================================

# OAuth credentials live in backend/secrets/ (gitignored):
#   secrets/youtube_client_secret.json  - OAuth "installed app" client
#   secrets/youtube_token.json          - authorized token (with refresh_token)
# Auto-publish is opt-in per render via the toggle in the UI.

# Privacy for auto-published videos (private, unlisted, public). Keep "private" for now.
YOUTUBE_PRIVACY_STATUS=private

# YouTube category id (27 = Education)
YOUTUBE_CATEGORY_ID=27

# Default tags applied to uploads (comma-separated)
YOUTUBE_DEFAULT_TAGS=education,flux,ai

# ============================================
# TTS (TEXT-TO-SPEECH) SETTINGS
# ============================================

# TTS language code (b for English)
TTS_LANG_CODE=b

# ============================================
# FILE UPLOAD SETTINGS
# ============================================

# Maximum upload size in bytes (50MB default)
MAX_UPLOAD_SIZE=52428800

# ============================================
# BACKGROUND TASK SETTINGS
# ============================================

# Task timeout in seconds (10 minutes default)
TASK_TIMEOUT=600

# ============================================
# LOGGING SETTINGS
# ============================================

# Log file name
LOG_FILE=app.log

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
