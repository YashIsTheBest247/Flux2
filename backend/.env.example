# Flux Video Generator - Environment Variables Example
# Copy this file to .env and fill in your values

# ============================================
# APPLICATION SETTINGS
# ============================================

# Application environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (True/False)
DEBUG=True

# Server host and port
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated list) - include the frontend Vite dev server
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173,http://127.0.0.1:5173

# ============================================
# API KEYS (REQUIRED)
# ============================================

# Google Gemini API Key - REQUIRED for script generation (free tier) and image fallback
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model used for text generation (scripts, questions) - free tier
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Pexels API Key - PRIMARY source for scene images (free)
# Get it from: https://www.pexels.com/api/
# If a topic returns no Pexels images, the app falls back to Gemini image generation
PEXELS_API_KEY=your_pexels_api_key_here

# ============================================
# VIDEO GENERATION SETTINGS
# ============================================

# Default video duration in seconds
DEFAULT_VIDEO_DURATION=60

# Default frames per second for video output
DEFAULT_VIDEO_FPS=24

# Default chunk size for subtitle splitting
DEFAULT_CHUNK_SIZE=10

# ============================================
# IMAGE SETTINGS (Pexels primary, Gemini fallback)
# ============================================

# Gemini image model used only when Pexels has no match (e.g. gemini-2.5-flash-image)
IMAGE_GEN_MODEL=gemini-2.5-flash-image

# Image aspect ratio (1:1, 3:4, 4:3, 9:16, 16:9) - maps to Pexels orientation
IMAGE_ASPECT_RATIO=1:1

# Delay between image API calls (seconds)
IMAGE_GEN_DELAY=2.0

# ============================================
# TTS (TEXT-TO-SPEECH) SETTINGS
# ============================================

# TTS language code (b for English)
TTS_LANG_CODE=b

# ============================================
# FILE UPLOAD SETTINGS
# ============================================

# Maximum upload size in bytes (50MB default)
MAX_UPLOAD_SIZE=52428800

# ============================================
# BACKGROUND TASK SETTINGS
# ============================================

# Task timeout in seconds (10 minutes default)
TASK_TIMEOUT=600

# ============================================
# LOGGING SETTINGS
# ============================================

# Log file name
LOG_FILE=app.log

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================
# NOTES
# ============================================

# 1. Paths are automatically configured based on the project structure
# 2. All resource directories (images, audio, videos, subtitles) are created automatically
# 3. Font and intro image paths are resolved from resources/font/font.ttf and resources/intro/intro.jpg
# 4. Make sure to create a .env file from this template and fill in your actual values
# 5. Never commit your .env file to version control!